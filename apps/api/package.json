{
  "name": "@mendoraci/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo 'lint pending'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run test/unit --coverage",
    "test:integration": "vitest run test/integration --coverage",
    "db:migrate": "node-pg-migrate up -m src/db/migrations -j cjs",
    "db:migrate:down": "node-pg-migrate down -m src/db/migrations -j cjs"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.1",
    "@mendoraci/mask-policy": "workspace:*",
    "@mendoraci/shared": "workspace:*",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.0",
    "pino-pretty": "^11.2.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.3",
    "node-pg-migrate": "^7.6.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.3"
  }
}
