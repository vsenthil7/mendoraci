# =============================================================================
# MendoraCI - Root .env.example
# Copy to .env then run scripts/set-secrets.ps1 (Windows) or
# scripts/set-secrets.sh (mac/Linux) to populate the secret values.
# NEVER commit a populated .env.
# =============================================================================

APP_NAME=mendoraci
APP_ENV=development
APP_VERSION=0.1.0

# --- Database (Postgres 16) ---
# CP-4b role split:
#   POSTGRES_ADMIN_USER/PASSWORD  - bootstrap superuser; used by api-migrate (DDL) and test setup pools
#   POSTGRES_APP_PASSWORD         - password for the runtime non-super `mendoraci_app` role
# The `mendoraci_app` role is created by infra/sql/01-create-app-role.sql at first
# postgres start, and that role is what api (Fastify) uses at runtime so that
# RLS FORCE policies actually fire.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mendoraci
POSTGRES_ADMIN_USER=mendoraci_admin
POSTGRES_ADMIN_PASSWORD=__CHANGE_ME__
POSTGRES_APP_PASSWORD=__CHANGE_ME__
POSTGRES_SSLMODE=disable

# DATABASE_URL is set per-service in docker-compose.yml:
#   api-migrate uses admin URL (for DDL)
#   api uses mendoraci_app URL (for RLS-enforced runtime)
# This var is left empty in .env so any process outside compose must set it.
DATABASE_URL=

# --- Redis (queue) ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible, dev) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=mendoraci_minio
S3_SECRET_KEY=__CHANGE_ME__
S3_BUCKET_EVIDENCE=mendoraci-evidence
S3_BUCKET_GOLDSETS=mendoraci-goldsets

# --- API ---
API_HOST=0.0.0.0
API_PORT=4000
API_BASE_URL=http://localhost:4000
JWT_SECRET=__CHANGE_ME__
JWT_ISSUER=mendoraci
JWT_AUDIENCE=mendoraci-app
HMAC_TENANT_SEED=__CHANGE_ME__

# --- Web (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- AI providers ---
# IBM Bob (primary). Leave blank to use mock-bob (built-in).
BOB_API_KEY=
BOB_API_URL=
BOB_MODEL_ID=bob-default
USE_MOCK_BOB=true

# Anthropic (substitute for dev only, if Bob unavailable)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-opus-4-7

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LOG_LEVEL=info

# --- Mask policy ---
MASK_POLICY_VERSION=v1.0.0
