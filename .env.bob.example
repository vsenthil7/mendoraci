# IBM Bob AI credentials — DO NOT COMMIT FILLED VERSION.
# Copy this to .env.bob (which is in .gitignore) and fill in real values.
# Loaded by docker-compose as a second env_file for the api service when
# USE_MOCK_BOB=false.

# Endpoint (region-specific). Examples:
#   https://us-south.ml.cloud.ibm.com
#   https://eu-de.ml.cloud.ibm.com
BOB_API_URL=

# IBM Cloud API key (from https://cloud.ibm.com/iam/apikeys)
BOB_API_KEY=

# Project / deployment / model id for the Bob deployment you have access to.
# At least ONE of project_id or deployment_id must be set.
BOB_PROJECT_ID=
BOB_DEPLOYMENT_ID=
BOB_MODEL_ID=ibm/granite-13b-instruct-v2

# Flip to false once .env.bob is populated and you want the live Bob path.
USE_MOCK_BOB=true

# Optional: hard ceiling on tokens per RCA / per repair-plan request (RT-016)
BOB_MAX_INPUT_TOKENS=8000
BOB_MAX_OUTPUT_TOKENS=2000
